# ============================================================
#  Vite production environment variables
#  Copy to .env.production (Vite auto-loads this when building)
#  Variables MUST start with VITE_ to be exposed to frontend
# ============================================================

# API URL: same domain, /api path → proxied by Nginx to backend
# Leave as /api/v1 if frontend and API share the same domain via Nginx
VITE_API_BASE_URL=/api/v1

# Google Analytics (optional)
VITE_GA_ID=G-SBWXZQB198
