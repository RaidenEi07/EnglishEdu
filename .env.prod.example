# ============================================================
#  EnglishEdu – Production Environment Variables
#  Copy to .env.prod and fill in all values before deploying
#  NEVER commit .env.prod to version control
# ============================================================

# ── Domains ─────────────────────────────────────────────────
# Main website domain (frontend + /api)
DOMAIN=14.225.192.133

# Moodle subdomain
LMS_DOMAIN=14.225.192.133

# ── Database (PostgreSQL for Spring Boot) ───────────────────
DB_PASSWORD=Admin@123
DB_NAME=sunshine_db

# ── Admin account (first-run seed) ──────────────────────────
ADMIN_USERNAME=admin
ADMIN_EMAIL=thinhdoquy@gmail.com
ADMIN_PASSWORD=Admin@123

# ── JWT ─────────────────────────────────────────────────────
# Must be at least 256-bit (32+ chars), random string
JWT_SECRET=69fedc8764d5faed2def109787e72de91456d79f94a8c43008bc0144046aaa73

# ── MinIO (file storage) ────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=Admin@123

JPA_DDL_AUTO=validate

# ── Moodle ──────────────────────────────────────────────────
# Admin token from: Moodle → Site Admin → Plugins → Web Services → Manage tokens
MOODLE_TOKEN=

# Must match auth_userkey plugin secret set in Moodle admin settings
MOODLE_SSO_SECRET=69fedc8764d5faed2def109787e72de91456d79f94a8c43008bc0144046aaa73

# Moodle admin account (used on first install only)
MOODLE_ADMIN_USER=admin
MOODLE_ADMIN_PASSWORD=Admin@123
MOODLE_ADMIN_EMAIL=gilgamesharch2607@gmail.com

# ── Email (Gmail example) ───────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=thinhdoquy@gmail.com
# Use Gmail App Password, not your account password
MAIL_PASSWORD=dieaxhbhptegnivu

