# ============================================================
#  EnglishEdu – Production Environment Variables
#  Copy to .env.prod and fill in all values before deploying
#  NEVER commit .env.prod to version control
# ============================================================

# ── Domains ─────────────────────────────────────────────────
# Main website domain (frontend + /api)
DOMAIN=sunshineschool.edu.vn

# Moodle subdomain
LMS_DOMAIN=lms.sunshineschool.edu.vn

# ── Database (PostgreSQL for Spring Boot) ───────────────────
DB_PASSWORD=CHANGE_ME_strong_db_password

# ── Admin account (first-run seed) ──────────────────────────
ADMIN_USERNAME=admin
ADMIN_EMAIL=thinhdoquy@gmail.com
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# ── JWT ─────────────────────────────────────────────────────
# Must be at least 256-bit (32+ chars), random string
JWT_SECRET=CHANGE_ME_minimum_32_chars_long_random_secret_key_here

# ── MinIO (file storage) ────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME_strong_minio_password

# ── Moodle ──────────────────────────────────────────────────
# Admin token from: Moodle → Site Admin → Plugins → Web Services → Manage tokens
MOODLE_TOKEN=PASTE_MOODLE_ADMIN_WEBSERVICE_TOKEN_HERE

# Must match auth_userkey plugin secret set in Moodle admin settings
MOODLE_SSO_SECRET=CHANGE_ME_strong_sso_secret

# Moodle admin account (used on first install only)
MOODLE_ADMIN_USER=admin
MOODLE_ADMIN_PASSWORD=CHANGE_ME_strong_moodle_admin_password
MOODLE_ADMIN_EMAIL=admin@sunshineschool.edu.vn

# ── Email (Gmail example) ───────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
# Use Gmail App Password, not your account password
MAIL_PASSWORD=your_gmail_app_password
